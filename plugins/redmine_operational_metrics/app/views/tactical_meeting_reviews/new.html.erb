<h2>Add Review: <%= @tactical_meeting_response.user.name %></h2>

<%= form_tag new_tactical_meeting_response_review_path(@tactical_meeting_response), method: :get do %>
  <p>
    <%= label_tag :role, "Role" %>
    <%= select_tag :role, options_for_select(Kra::ROLES, @role), include_blank: "Select a role" %>
    <%= submit_tag "Load KRAs" %>
  </p>
<% end %>

<% if @role.present? %>
  <% if @kras.empty? %>
    <p>
      No KRAs configured for <%= @role %> yet.
      <%= link_to "Set up KRAs", edit_kra_path(role: @role) %>.
    </p>
  <% else %>
    <%= form_tag tactical_meeting_response_review_path(@tactical_meeting_response), method: :post do %>
      <%= hidden_field_tag :role, @role %>

      <table class="list">
        <thead>
          <tr><th>KRA</th><th>Weight</th><th>Score (0-100)</th></tr>
        </thead>
        <tbody>
          <% @kras.each do |kra| %>
            <tr>
              <td><%= kra.name %></td>
              <td><%= kra.weight %>%</td>
              <td>
                <%= number_field_tag "scores[#{kra.id}]", params.dig(:scores, kra.id.to_s), min: 0, max: 100, step: 0.01, required: true %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>

      <p>
        <%= label_tag "tactical_meeting_review[comment]", "Overall Comment" %><br>
        <%= text_area_tag "tactical_meeting_review[comment]", params.dig(:tactical_meeting_review, :comment), rows: 4, style: "width: 100%;" %>
      </p>

      <%= submit_tag "Save Review" %>
    <% end %>
  <% end %>
<% end %>

<p><%= link_to "Back to Response", tactical_meeting_response_path(@tactical_meeting_response) %></p>
