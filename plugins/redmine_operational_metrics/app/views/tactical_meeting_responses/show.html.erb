<h2>Tactical Meeting Response: <%= @tactical_meeting_response.user.name %></h2>
<p>Meeting: <%= @tactical_meeting.start_date %> to <%= @tactical_meeting.end_date %></p>

<% if User.current.admin? %>
  <p><%= link_to "Edit", edit_tactical_meeting_response_path(@tactical_meeting_response), class: 'icon icon-edit' %></p>
<% end %>

<div class="box">
  <div style="margin-bottom: 20px; font-size: 1.1em;">
    <strong>Break down count:</strong> <%= @tactical_meeting_response.break_down_count %> <br>
    <strong>Break through count:</strong> <%= @tactical_meeting_response.break_through_count %>
  </div>

  <fieldset>
    <legend>Review</legend>
    <p><strong>What was the goal ?</strong><br><%= simple_format @tactical_meeting_response.individual_goal %></p>
    <p><strong>What is done ?</strong><br><%= simple_format @tactical_meeting_response.what_was_done %></p>
    <p><strong>What is not done ?</strong><br><%= simple_format @tactical_meeting_response.what_not_done %></p>
  </fieldset>

  <fieldset>
    <legend>Reflect</legend>
    <p><strong>What was missing from your end ?</strong><br><%= simple_format @tactical_meeting_response.missing_from_my_end %></p>
    <p><strong>What did you learn ?</strong><br><%= simple_format @tactical_meeting_response.learnings %></p>
  </fieldset>

  <fieldset>
    <legend>Result</legend>
    <p><strong>What will be different from your end ?</strong><br><%= simple_format @tactical_meeting_response.different_from_my_end %></p>
    <p><strong>What will you get done and by when ?</strong><br><%= simple_format @tactical_meeting_response.get_done_by_when %></p>
  </fieldset>

  <fieldset>
    <legend>Creation</legend>
    <p><strong>Creation : Next, Fortnight, Goals,</strong><br><%= simple_format @tactical_meeting_response.next_fortnight_goals %></p>
  </fieldset>

  <fieldset>
    <legend>Facilitate</legend>
    <p><strong>Facilitate sharing of problems : Problems, Doubts, Fears</strong><br><%= simple_format @tactical_meeting_response.problems_doubts_fears %></p>
  </fieldset>

  <p><strong>Closure Notes</strong><br><%= simple_format @tactical_meeting_response.closure_notes %></p>
</div>

<% tactical_meeting_review = @tactical_meeting_response.tactical_meeting_review %>
<div class="box">
  <h3>KRA Review</h3>
  <% if tactical_meeting_review %>
    <p><strong>Role:</strong> <%= tactical_meeting_review.role %></p>
    <table class="list">
      <thead>
        <tr><th>KRA</th><th>Weight</th><th>Score</th><th>Weighted Contribution</th></tr>
      </thead>
      <tbody>
        <% tactical_meeting_review.tactical_meeting_review_items.each do |item| %>
          <tr>
            <td><%= item.kra_name %></td>
            <td><%= item.weight %>%</td>
            <td><%= item.score %></td>
            <td><%= (item.score.to_f * item.weight.to_f / 100.0).round(2) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
    <p><strong>Overall Score:</strong> <%= tactical_meeting_review.overall_score %></p>
    <p><strong>Comment</strong><br><%= simple_format tactical_meeting_review.comment %></p>
    <% if User.current.admin? %>
      <p><%= link_to "Edit Review", edit_tactical_meeting_response_review_path(@tactical_meeting_response), class: 'icon icon-edit' %></p>
    <% end %>
  <% else %>
    <p>No review yet.</p>
    <% if User.current.admin? %>
      <p><%= link_to "Add Review", new_tactical_meeting_response_review_path(@tactical_meeting_response), class: 'icon icon-add' %></p>
    <% end %>
  <% end %>
</div>

<p><%= link_to "Back to Responses", tactical_meeting_responses_path(tactical_meeting_id: @tactical_meeting.id) %></p>
